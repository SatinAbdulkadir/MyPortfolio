@model List<MyPortfolio.BusinessLayer.Dtos.PortfolioDtos.ResultPortfolioDto>
@{
    ViewData["Title"] = "Proje Listesi";
    Layout = "_AdminLayout";
    int count = 0;
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
        <h6 class="m-0 fw-bold text-primary"><i class="fas fa-briefcase me-2"></i> Proje Portfolyosu</h6>
        <a href="/AdminPortfolio/CreatePortfolio" class="btn btn-primary btn-sm shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50 me-1"></i> Yeni Proje Ekle
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th style="width: 100px;">Görsel</th>
                        <th>Proje Adı</th>
                        <th>Kategori / Alt Başlık</th>
                        <th class="text-center">Link</th>
                        <th style="width: 150px;" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td>
                                    <img src="@item.ImageUrl" class="rounded shadow-sm"
                                         style="width: 80px; height: 50px; object-fit: cover;"
                                         alt="Project" />
                                </td>
                                <td class="fw-bold">@item.Title</td>
                                <td><span class="badge bg-info text-dark">@item.SubTitle</span></td>
                                <td class="text-center">
                                    <a href="@item.Url" target="_blank" class="btn btn-link btn-sm text-decoration-none">
                                        <i class="fas fa-external-link-alt"></i> Git
                                    </a>
                                </td>
                                <td class="text-center">
                                    <a href="/AdminPortfolio/UpdatePortfolio/@item.Id" class="btn btn-outline-warning btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/AdminPortfolio/DeletePortfolio/@item.Id" class="btn btn-outline-danger btn-sm"
                                       onclick="return confirm('Bu projeyi silmek istediğine emin misin reis?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="fas fa-layer-group d-block mb-2 fa-3x"></i>
                                Henüz bir proje eklenmemiş.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>