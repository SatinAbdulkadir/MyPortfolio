@model MyPortfolio.BusinessLayer.Dtos.SocialMediaDtos.UpdateSocialMediaDto
@{
    ViewData["Title"] = "Sosyal Medya Düzenle";
    Layout = "_AdminLayout";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 fw-bold text-warning"><i class="fas fa-edit me-2"></i> Sosyal Medya Hesabını Düzenle</h6>
    </div>
    <div class="card-body">
        @* novalidate: Tarayıcıyı devre dışı bırakıp bizim profesyonel validator'ı açar *@
        <form method="post" novalidate>
            @* ID bilgisini saklıyoruz *@
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label fw-bold">Platform Adı</label>
                <input type="text" asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Profil URL</label>
                <input type="url" asp-for="Url" class="form-control" />
                <span asp-validation-for="Url" class="text-danger small fw-bold"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">İkon Kodu</label>
                <div class="input-group">
                    <span class="input-group-text bg-light text-primary">
                        <i class="@Model.Icon"></i> @* Mevcut ikonu burada önizleme yapıyoruz *@
                    </span>
                    <input type="text" asp-for="Icon" class="form-control" />
                </div>
                <span asp-validation-for="Icon" class="text-danger small fw-bold"></span>
                <br />
                <small class="text-muted">Mevcut ikon kodu: <code>@Model.Icon</code></small>
            </div>

            <div class="text-end mt-4">
                <a href="/AdminSocialMedia/Index" class="btn btn-secondary shadow-sm px-4 me-2">İptal</a>
                <button type="submit" class="btn btn-warning shadow-sm px-5 text-dark fw-bold">
                    <i class="fas fa-sync-alt me-2"></i> Değişiklikleri Uygula
                </button>
            </div>
        </form>
    </div>
</div>