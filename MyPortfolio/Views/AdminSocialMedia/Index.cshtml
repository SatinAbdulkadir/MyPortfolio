@model List<MyPortfolio.BusinessLayer.Dtos.SocialMediaDtos.ResultSocialMediaDto>
@{
    ViewData["Title"] = "Sosyal Medya Hesaplarım";
    Layout = "_AdminLayout";
    int count = 0;
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
        <h6 class="m-0 fw-bold text-primary"><i class="fas fa-share-alt me-2"></i> Sosyal Medya Yönetimi</h6>
        <a href="/AdminSocialMedia/CreateSocialMedia" class="btn btn-primary btn-sm shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50 me-1"></i> Yeni Mecra Ekle
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th style="width: 80px;" class="text-center">İkon</th>
                        <th>Platform Adı</th>
                        <th>Profil Linki (URL)</th>
                        <th style="width: 200px;" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td class="text-center">
                                    @* İkonu burada canlı gösteriyoruz *@
                                    <div class="bg-light p-2 rounded text-primary">
                                        <i class="@item.Icon fa-2x"></i>
                                    </div>
                                </td>
                                <td class="fw-bold align-middle">@item.Title</td>
                                <td class="align-middle">
                                    <a href="@item.Url" target="_blank" class="text-info text-decoration-none">
                                        <i class="fas fa-external-link-alt me-1 small"></i> @item.Url
                                    </a>
                                </td>
                                <td class="text-center align-middle">
                                    <a href="/AdminSocialMedia/UpdateSocialMedia/@item.Id" class="btn btn-outline-warning btn-sm me-1">
                                        <i class="fas fa-edit"></i> Düzenle
                                    </a>
                                    <a href="/AdminSocialMedia/DeleteSocialMedia/@item.Id" class="btn btn-outline-danger btn-sm"
                                       onclick="confirm('Bu hesabı silmek istediğine emin misin?')">
                                        <i class="fas fa-trash"></i> Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="fas fa-hashtag d-block mb-2 fa-3x"></i>
                                Henüz bir sosyal medya hesabı eklememişsin reis.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>