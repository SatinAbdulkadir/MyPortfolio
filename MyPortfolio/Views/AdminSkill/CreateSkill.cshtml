@model MyPortfolio.BusinessLayer.Dtos.SkillDtos.CreateSkillDto
@{
    ViewData["Title"] = "Yeni Yetenek Ekle";
    Layout = "_AdminLayout";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 fw-bold text-primary"><i class="fas fa-plus-circle me-2"></i> Yeni Yetenek Ekle</h6>
    </div>
    <div class="card-body">
        <form method="post" novalidate>
            @* Value alanını arka planda 100 olarak gönderiyoruz, ekranda kutusu olmayacak *@
            <input type="hidden" asp-for="Value" value="100" />

            <div class="row">
                <div class="col-md-7">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Yetenek Başlığı</label>
                        <input type="text" asp-for="Title" class="form-control" placeholder="Örn: .NET Core, React, SQL..." />
                        <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
                        <br />
                        <small class="text-muted">Öne çıkarmak istediğin teknolojiyi yaz reis.</small>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="mb-3">
                        <label class="form-label fw-bold">İkon Sınıfı</label>
                        <input type="text" asp-for="Icon" class="form-control" placeholder="Örn: fab fa-cuttlefish" />
                        <span asp-validation-for="Icon" class="text-danger small fw-bold"></span>
                        <br />
                        <small class="text-muted"><a href="https://fontawesome.com/v5/search?m=free" target="_blank">İkon kütüphanesine git.</a></small>
                    </div>
                </div>
            </div>

            <div class="text-end mt-4">
                <a href="/AdminSkill/Index" class="btn btn-secondary shadow-sm px-4 me-2">
                    <i class="fas fa-arrow-left me-2"></i> Vazgeç
                </a>
                <button type="submit" class="btn btn-primary shadow-sm px-5">
                    <i class="fas fa-save me-2"></i> Yeteneği Kaydet
                </button>
            </div>
        </form>
    </div>
</div>