@model MyPortfolio.BusinessLayer.Dtos.SkillDtos.UpdateSkillDto
@{
    ViewData["Title"] = "Yetenek Güncelle";
    Layout = "_AdminLayout";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 fw-bold text-warning"><i class="fas fa-edit me-2"></i> Yetenek Bilgilerini Düzenle</h6>
    </div>
    <div class="card-body">
        <form method="post" novalidate>
            @* ID ve Value değerlerini saklıyoruz *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Value" />

            <div class="row">
                @* Başlık Alanı - Biraz daha genişlettik *@
                <div class="col-md-7">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Yetenek Başlığı</label>
                        <input type="text" asp-for="Title" class="form-control" placeholder="Örn: .NET Core" />
                        <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
                    </div>
                </div>

                @* İkon Alanı *@
                <div class="col-md-5">
                    <div class="mb-3">
                        <label class="form-label fw-bold">İkon Sınıfı</label>
                        <input type="text" asp-for="Icon" class="form-control" placeholder="Örn: fab fa-cuttlefish" />
                        <span asp-validation-for="Icon" class="text-danger small fw-bold"></span>
                    </div>
                </div>
            </div>

            <div class="text-end mt-4">
                <a href="/AdminSkill/Index" class="btn btn-secondary shadow-sm px-4 me-2">
                    <i class="fas fa-arrow-left me-2"></i> İptal
                </a>
                <button type="submit" class="btn btn-warning shadow-sm px-5">
                    <i class="fas fa-sync-alt me-2"></i> Değişiklikleri Kaydet
                </button>
            </div>
        </form>
    </div>
</div>