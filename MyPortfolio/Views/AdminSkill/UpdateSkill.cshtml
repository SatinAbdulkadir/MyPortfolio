@model MyPortfolio.BusinessLayer.Dtos.SkillDtos.UpdateSkillDto
@{
    ViewData["Title"] = "Yetenek Güncelle";
    Layout = "_AdminLayout";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 fw-bold text-warning"><i class="fas fa-edit me-2"></i> Yetenek Bilgilerini Düzenle</h6>
    </div>
    <div class="card-body">
        <form method="post">
            @* ID'yi saklamayı unutma reis, yoksa güncelleme yapmaz! *@
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Yetenek Başlığı</label>
                        <input type="text" asp-for="Title" class="form-control" placeholder="Örn: .NET Core" required />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Başarı Oranı (%)</label>
                        <input type="number" asp-for="Value" class="form-control" min="0" max="100" required />
                    </div>
                </div>
            </div>

            <div class="text-end mt-4">
                <a href="/AdminSkill/Index" class="btn btn-secondary shadow-sm px-4 me-2">
                    <i class="fas fa-arrow-left me-2"></i> İptal
                </a>
                <button type="submit" class="btn btn-warning shadow-sm px-5">
                    <i class="fas fa-sync-alt me-2"></i> Değişiklikleri Kaydet
                </button>
            </div>
        </form>
    </div>
</div>