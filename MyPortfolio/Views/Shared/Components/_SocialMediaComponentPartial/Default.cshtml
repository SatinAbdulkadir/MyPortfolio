@model List<MyPortfolio.BusinessLayer.Dtos.SocialMediaDtos.ResultSocialMediaDto>

@* row: Satır başlatır
   row-cols-3: Her satıra tam olarak 3 sütun sığdırır
   g-2: İkonlar arası boşluk (gutter) bırakır
   justify-content-start: Sola yaslar
*@
<div class="row row-cols-3 g-2 mx-0" style="width: 135px;">
    @if (Model != null && Model.Count > 0)
    {
        @foreach (var item in Model)
        {
            <div class="col px-0">
                <a href="@item.Url" class="social-icon-btn d-flex align-items-center justify-content-center" target="_blank" title="@item.Title" style="width: 35px; height: 35px;">
                    <i class="@item.Icon"></i>
                </a>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <p class="text-muted small">Mecralar bekleniyor...</p>
        </div>
    }
</div>