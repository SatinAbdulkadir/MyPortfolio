@model MyPortfolio.BusinessLayer.Dtos.FeatureDtos.ResultFeatureDto

<section id="home" class="vh-100 d-flex align-items-center text-center bg-light border-bottom">
    <div class="container">
        @if (Model != null)
        {
            <h6 class="text-primary text-uppercase fw-bold">Hoş Geldiniz</h6>
            <h1 class="display-1 fw-bold my-3">@Model.Title</h1>
            <p class="lead mb-4 text-secondary">@Model.Description</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="#portfolio" class="btn btn-primary btn-lg px-4">Projelerimi Gör</a>
                <a href="#contact" class="btn btn-outline-dark btn-lg px-4">İletişime Geç</a>
            </div>
        }
    </div>
</section>