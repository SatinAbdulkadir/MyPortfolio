@model List<MyPortfolio.BusinessLayer.Dtos.PortfolioDtos.ResultPortfolioDto>

<section id="portfolio">
    <div class="container">
        <div class="section-title">
            <h2>Projelerim</h2>
            <p>Bugüne kadar tamamladığım bazı çalışmalar.</p>
        </div>

        <div class="row">
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6 portfolio-item">
                        <div class="portfolio-wrap">
                            @* Veritabanında resim yolu varsa onu basar *@
                            <img src="@item.ImageUrl" class="img-fluid" alt="@item.Title">
                            <div class="portfolio-info">
                                <h4>@item.Title</h4>
                                <p>@item.SubTitle</p>
                                <div class="portfolio-links">
                                    <a href="@item.Url" target="_blank" title="Projeyi Gör">
                                        <i class="bx bx-link"></i> Detay
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">Henüz bir proje eklenmemiş reis.</div>
            }
        </div>
    </div>
</section>
