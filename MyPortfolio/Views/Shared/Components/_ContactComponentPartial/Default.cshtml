@using MyPortfolio.BusinessLayer.Dtos.ContactDtos

@model ResultContactDto

<section id="contact" class="section-padding">
    <div class="container">
        <div class="section-title text-center">
            <span class="subtitle">BANA ULAŞIN</span>
            <h2 class="title">İletişim</h2>
        </div>

        @if (Model != null)
        {
            <div class="contact-wrapper">
                <div class="contact-header-info text-center mb-5">
                    <h3 class="contact-title">@Model.Title</h3>
                    <p class="contact-desc">@Model.Description</p>
                </div>

                <div class="contact-grid">
                    

                    @* 2. Kutu: E-Posta *@
                    <div class="contact-card">
                        <div class="icon-box"><i class="fa fa-envelope"></i></div>
                        <div class="info-content">
                            <span class="info-label">E-Posta</span>
                            <p>@Model.Email1</p>
                            @if (!string.IsNullOrEmpty(Model.Email2))
                            {
                                <p>@Model.Email2</p>
                            }
                        </div>
                    </div>

                    @* 3. Kutu: Adres *@
                    <div class="contact-card">
                        <div class="icon-box"><i class="fa fa-map-marker-alt"></i></div>
                        <div class="info-content">
                            <span class="info-label">Adres</span>
                            <p>@Model.Address</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-dark text-center">İletişim bilgisi bulunamadı.</div>
        }
    </div>
</section>