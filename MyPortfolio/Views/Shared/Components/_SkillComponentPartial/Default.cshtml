@model List<MyPortfolio.BusinessLayer.Dtos.SkillDtos.ResultSkillDto>

<section id="skills" class="section-padding">
    <div class="container">
        <div class="section-title">
            <span class="subtitle">YETENEKLERİM</span>
            <h2 class="title">Teknoloji Envanterim</h2>
        </div>

        <div class="skills-grid">
            @foreach (var item in Model)
            {
                <div class="skill-card">
                    @* 🔍 KRİTİK NOKTA BURASI: Sabit ikon yerine DB'den geleni yazıyoruz *@
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <i class="@item.Icon"></i>
                    }
                    else
                    {
                        @* Eğer DB'de ikon boşsa ayıp olmasın diye terminal gösteriyoruz *@
                        <i class="fas fa-terminal"></i>
                    }
                    <p class="skill-name">@item.Title</p>
                </div>
            }
        </div>
    </div>
</section>