<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio | Reis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #0f1113;
            color: #e9ecef;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* Sol Menü (Sidebar) */
        .sidebar {
            width: 280px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: #16191c;
            border-right: 1px solid #2d3238;
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .nav-link {
            color: #adb5bd;
            padding: 0.8rem 1rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
            transition: 0.3s;
            font-weight: 500;
        }

            .nav-link:hover, .nav-link.active {
                background: #2d3238;
                color: #fff;
            }

            .nav-link i {
                margin-right: 10px;
                width: 20px;
                text-align: center;
            }

        /* Sağ İçerik Alanı */
        .main-content {
            margin-left: 280px;
            padding: 0;
            width: calc(100% - 280px);
        }

        section {
            padding: 80px 10% 80px 10%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-bottom: 1px solid #1e2227;
        }

        h2.section-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 3rem;
            color: #fff;
            border-left: 5px solid #0d6efd;
            padding-left: 15px;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="mb-5 px-3">
            <h4 class="fw-bold text-white">REİS <span class="text-primary">.</span></h4>
        </div>

        <nav class="nav flex-column">
            <a class="nav-link active" href="#home"><i class="fas fa-home"></i> Ana Sayfa</a>
            <a class="nav-link" href="#about"><i class="fas fa-user"></i> Hakkımda</a>
            <a class="nav-link" href="#skills"><i class="fas fa-code"></i> Yetenekler</a>
            <a class="nav-link" href="#experience"><i class="fas fa-briefcase"></i> Deneyimler</a>
            <a class="nav-link" href="#portfolio"><i class="fas fa-layer-group"></i> Projeler</a>
            <a class="nav-link" href="#contact"><i class="fas fa-envelope"></i> İletişim</a>
        </nav>

        <div class="mt-auto px-3">
            @await Component.InvokeAsync("_SocialMediaComponentPartial")
        </div>
    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>