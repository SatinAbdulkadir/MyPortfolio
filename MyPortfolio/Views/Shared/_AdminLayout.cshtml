<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Paneli - MyPortfolio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin_sidebar.css" />
</head>
<body>
    <div class="d-flex" id="wrapper">
        @await Html.PartialAsync("_AdminSidebarPartial")

        <div id="page-content-wrapper" class="w-100">
            @await Html.PartialAsync("_AdminNavbarPartial")

            <div class="container-fluid py-4">
                @RenderBody()
            </div>
        </div>
    </div>

    @* 1. Kütüphaneler *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* 2. Merkezi Mesaj Sistemi (PartialView olarak da yapabilirsin direkt buraya da yazabilirsin) *@
    @if (TempData["ValidationResult"] != null)
    {
        <script>
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 1000,
                timerProgressBar: true
            });

            var status = '@TempData["ValidationResult"]';
            if (status === "error") {
                Toast.fire({ icon: 'error', title: 'Hata!', text: 'Lütfen formdaki eksikleri giderin reis.' });
            } else if (status === "success") {
                Toast.fire({ icon: 'success', title: 'Başarılı!', text: 'İşlemin tıkır tıkır kaydedildi.' });
            }
        </script>
    }

    @* 3. KRİTİK SATIR: View'lardan gelen özel scriptleri buraya basar *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>